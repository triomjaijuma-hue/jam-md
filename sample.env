# ====================================================
# JAM-MD — Environment Variables
# Rename this file to .env before running locally.
# On cloud platforms (Wispbyte, Railway, Render, etc.)
# set these as environment variables in the dashboard.
# ====================================================

# --------------------------------------------------
# REQUIRED — bot will not start without these
# --------------------------------------------------

# Your WhatsApp session string (generate it by pairing once locally or via /pair page)
SESSION_ID=

# Your WhatsApp number — digits only, no + or spaces (e.g. 2348012345678)
OWNER_NUMBER=2348012345678

# Same as OWNER_NUMBER — needed on cloud/non-TTY environments so the bot
# can request a pairing code automatically without a terminal prompt.
PAIRING_NUMBER=2348012345678

# Port to listen on (Wispbyte/Railway/Render usually sets this automatically)
PORT=5000

# --------------------------------------------------
# CLOUD DEPLOYMENT — set your app's public URL so
# the bot prints the correct /pair link in the logs
# --------------------------------------------------

# Your Wispbyte/Railway/Render/custom public URL (no trailing slash)
# Example: https://my-bot.wispbyte.com
APP_URL=

# --------------------------------------------------
# BOT IDENTITY
# --------------------------------------------------

BOT_NAME=JAM-MD
BOT_OWNER=Jaiton fangs
PACKNAME=JAM-MD
COMMAND_MODE=public
TIMEZONE=Africa/Lagos
PREFIXES=.,!,/

# --------------------------------------------------
# DATABASE (Optional — leave empty to use JSON files)
# --------------------------------------------------

# MongoDB
MONGO_URL=

# PostgreSQL
POSTGRES_URL=

# MySQL
MYSQL_URL=

# SQLite (e.g. ./data/baileys.db)
DB_URL=

# --------------------------------------------------
# OPTIONAL API KEYS
# --------------------------------------------------

REMOVEBG_KEY=
