# ____REMOVE THIS LINE AFTER RENAMING sample.env to .env ____

# PUT YOUR SESSION ID BELOW (Required)
SESSION_ID=

# PUT YOUR REMOVE BACKGROUND KEY (Optional)
REMOVEBG_KEY=

PORT=5000

# If you don't have session id and want pairing code for connection 
PAIRING_NUMBER=


# Use One Of Following:
# Database Configuration (Optional but recommended)
# Leave empty to use JSON file storage

# MongoDB (Optional)
MONGO_URL=

# PostgreSQL (Optional)
POSTGRES_URL=

# MySQL (Optional)
MYSQL_URL=

# SQLite Path (Optional)
# Example: DB_URL=./data/baileys.db
DB_URL=

PREFIXES=.,!,/

PACKNAME=MEGA-MD

BOT_NAME=MEGA-MD-PRO

OWNER_NUMBER=256765309986

COMMAND_MODE=private

BOT_OWNER=GlobalTechInfo

TIMEZONE=Asia/Karachi

# ── Session Backup (Required on Railway to fix "Waiting for this message") ──
# Without these, every Railway restart loses key updates → messages can't decrypt.
#
# Setup:
#   1. Create a secret Gist at https://gist.github.com
#      filename: creds.json  |  content: {}  |  click "Create secret gist"
#   2. Copy the Gist ID from the URL bar
#   3. Create a GitHub token at https://github.com/settings/tokens
#      with the "gist" scope only
#   4. Paste both values below and set them as Railway env vars
GITHUB_TOKEN=
GIST_ID=

# ── AI Provider (Required for smart replies) ────────────────────────────────
# Set these on your hosting platform (Railway/Render/Heroku) so the AI
# provider and keys survive every crash and redeploy automatically.
# Without these, the bot falls back to the free Mistral provider.
#
# AI_PROVIDER — which provider to use: gemini | groq | openai | mistral
AI_PROVIDER=gemini

# Gemini API key (free at https://aistudio.google.com/apikey)
# Recommended — has built-in Google Search for current events
GEMINI_API_KEY=

# Groq API key (free at https://console.groq.com)
GROQ_API_KEY=

# OpenAI API key (paid, https://platform.openai.com)
OPENAI_API_KEY=
